{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Home Assistant",
      "type": "shell",
      "command": "supervisor_run",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Addon",
      "type": "shell",
      "command": "ha addons stop \"local_${input:addonName}\"; ha addons start \"local_${input:addonName}\"; docker logs --follow \"addon_local_${input:addonName}\"",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": false
      }
    },
    {
      "label": "Rebuild and Start Addon",
      "type": "shell",
      "command": "ha addons rebuild --force \"local_${input:addonName}\"; ha addons start \"local_${input:addonName}\"; docker logs --follow \"addon_local_${input:addonName}\"",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Container",
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "command": [
        "docker",
        "run",
        "--log-driver=none",
        "--rm",
        "-it",
        "--name",
        "builder",
        "--privileged",
        "-v",
        "./music-assistant-alexa-api:/data",
        "-v",
        "/var/run/docker.sock:/var/run/docker.sock:ro",
        "ghcr.io/home-assistant/${input:builderArch}-builder",
        "-t",
        "/data",
        "--amd64",
        "--aarch64",
        "--test",
        "-i",
        "{arch}-addon-ma-alexa-api",
        "-d",
        "local"
      ]
    }
  ],
  "inputs": [
    {
      "id": "addonName",
      "type": "pickString",
      "description": "Name of addon (to add your addon to this list, please edit .vscode/tasks.json)",
      "options": [
        "ma_alexa_api",
      ]
    },
    {
      "id": "builderArch",
      "type": "pickString",
      "description": "Architecture for builder (to add your architecture to this list, please edit .vscode/tasks.json)",
      "options": [
        "amd64",
        "aarch64"
      ]
    }
  ]
}
